<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_purchase" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.jcdecaux.purchase.order.report</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='purchase_setting_container']" position="inside">
                <setting
                    id="jcdecaux_purchase_general_terms_setting"
                    string="Condiciones generales JCDecaux"
                    help="Texto global impreso en todas las órdenes de compra JCDecaux."
                    groups="base.group_system"
                >
                    <field
                        name="jcdecaux_purchase_general_terms"
                        class="w-100"
                        placeholder="Condiciones generales de compra..."
                    />
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
