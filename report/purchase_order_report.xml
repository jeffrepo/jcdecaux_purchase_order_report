<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_purchase_order_jcdecaux" model="report.paperformat">
        <field name="name">Orden de compra JCDecaux</field>
        <field name="default" eval="False"/>
        <field name="format">Letter</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">8</field>
        <field name="margin_bottom">8</field>
        <field name="margin_left">7</field>
        <field name="margin_right">7</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">3</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_purchase_order_jcdecaux" model="ir.actions.report">
        <field name="name">Orden de compra JCDecaux</field>
        <field name="model">purchase.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">jcdecaux_purchase_order_report.report_purchase_order_jcdecaux</field>
        <field name="report_file">jcdecaux_purchase_order_report.report_purchase_order_jcdecaux</field>
        <field name="print_report_name">'Orden de compra JCDecaux - %s' % (object.name)</field>
        <field name="binding_model_id" ref="purchase.model_purchase_order"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_purchase_order_jcdecaux"/>
    </record>
</odoo>
